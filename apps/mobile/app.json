{
  "expo": {
    "name": "Kids Activity Finder",
    "slug": "kids-activity-finder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "kidsapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Kids Activity Finder to use your location to find activities nearby."
        }
      ]
    ],
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.kidsactivityfinder"
    },
    "ios": {
      "bundleIdentifier": "com.kidsactivityfinder",
      "supportsTablet": true
    }
  }
}
