# Foursquare Places API (free tier: 1,000 calls/day)
# Get yours at: https://foursquare.com/developers/
FOURSQUARE_API_KEY=your_foursquare_api_key_here

# Mapbox (free up to 50k map loads/month)
# Get yours at: https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_public_token_here

# Supabase (get these from your Supabase project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

